{
  "provider-schema-version": "0.1.0",
  "provider-name": "tree-sitter",
  "configs": [
    {
      "config-name": "tree_sitter_all",
      "linux-x86_64":    { "binary": "libtree_sitter_all.a", "flags-groups": [["-lc++"], ["-lpthread"], ["-ldl"], ["-lm"]] },
      "linux-aarch64":   { "binary": "libtree_sitter_all.a", "flags-groups": [["-lc++"], ["-lpthread"], ["-ldl"], ["-lm"]] },
      "macos-x86_64":    { "binary": "libtree_sitter_all.a", "flags-groups": [["-lc++"]] },
      "macos-aarch64":   { "binary": "libtree_sitter_all.a", "flags-groups": [["-lc++"]] },
      "windows-x86_64":  { "binary": "tree_sitter_all.lib",  "flags-groups": [["-lntdll"], ["-lmsvcrt"]] },
      "windows-aarch64": { "binary": "tree_sitter_all.lib",  "flags-groups": [["-lntdll"], ["-lmsvcrt"]] }
    }
  ]
}
